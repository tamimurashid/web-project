<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ujamaa Hostel | Your Home in Arusha, Tanzania</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg fixed-top shadow-sm glass-nav" id="mainNav">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <i class="bi bi-building me-2"></i>
                <span class="brand-text">Ujamaa<span class="text-primary">Hostel</span></span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link" href="#home" data-en="Home" data-sw="Mwanzo">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#rooms" data-en="Rooms" data-sw="Vyumba">Rooms</a></li>
                    <li class="nav-item"><a class="nav-link" href="#amenities" data-en="Amenities" data-sw="Huduma">Amenities</a></li>
                    <li class="nav-item"><a class="nav-link" href="#gallery" data-en="Gallery" data-sw="Nyumba ya Picha">Gallery</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact" data-en="Contact" data-sw="Mawasiliano">Contact</a></li>
                    <!-- Language Switcher -->
                    <li class="nav-item dropdown lang-switcher ms-lg-3">
                        <a class="nav-link dropdown-toggle rounded-pill" href="#" id="langDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-translate me-1"></i> <span id="currentLangText">EN</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" aria-labelledby="langDropdown">
                            <li><a class="dropdown-item active" href="#" onclick="changeLanguage('en')">English</a></li>
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('sw')">Kiswahili</a></li>
                        </ul>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <a href="#booking" class="btn btn-primary rounded-pill px-4" data-en="Book Now" data-sw="Weka Nafasi">Book Now</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero-section">
        <div class="hero-overlay"></div>
        <div class="hero-particles" id="particles-js"></div>
        <div class="container position-relative z-1">
            <div class="row min-vh-100 align-items-center">
                <div class="col-lg-8">
                    <div class="hero-content" data-aos="fade-up" data-aos-duration="1000">
                        <span class="badge bg-white text-dark mb-3 px-3 py-2 rounded-pill">
                            <i class="bi bi-geo-alt me-1"></i> Arusha, Tanzania
                        </span>
                        <h1 class="display-3 fw-bold mb-4" data-en="Experience Authentic African Hospitality" data-sw="Furahia Ukarimu wa Kweli wa Kiafrika">Experience Authentic African Hospitality</h1>
                        <p class="lead mb-4" data-en="Welcome to Ujamaa Hostel - Your cozy home away from home in the heart of Arusha. Perfect base for Kilimanjaro adventures and Safari expeditions." data-sw="Karibu Ujamaa Hostel - Nyumba yako ya starehe mbali na nyumbani katikati ya Arusha. Kituo bora kwa safari za Kilimanjaro na Safari.">Welcome to Ujamaa Hostel - Your cozy home away from home in the heart of Arusha. Perfect base for Kilimanjaro adventures and Safari expeditions.</p>
                        <div class="d-flex flex-wrap gap-3">
                            <a href="#rooms" class="btn btn-primary btn-lg rounded-pill px-4">
                                <i class="bi bi-calendar-check me-2"></i>View Rooms
                            </a>
                            <a href="#contact" class="btn btn-outline-light btn-lg rounded-pill px-4">
                                <i class="bi bi-telephone me-2"></i>Contact Us
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Quick Stats -->
        <div class="quick-stats">
            <div class="container">
                <div class="row text-center">
                    <div class="col-6 col-md-3 mb-3 mb-md-0" data-aos="fade-up" data-aos-delay="100">
                        <div class="stat-item">
                            <h3 class="fw-bold text-white">4.5★</h3>
                            <p class="text-white-50 mb-0">TripAdvisor Rating</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3 mb-md-0" data-aos="fade-up" data-aos-delay="200">
                        <div class="stat-item">
                            <h3 class="fw-bold text-white">500+</h3>
                            <p class="text-white-50 mb-0">Happy Guests</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3 mb-md-0" data-aos="fade-up" data-aos-delay="300">
                        <div class="stat-item">
                            <h3 class="fw-bold text-white">24/7</h3>
                            <p class="text-white-50 mb-0">Support</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3 mb-md-0" data-aos="fade-up" data-aos-delay="400">
                        <div class="stat-item">
                            <h3 class="fw-bold text-white">Free</h3>
                            <p class="text-white-50 mb-0">Wi-Fi</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Booking Widget -->
    <section class="booking-widget-section" id="booking">
        <div class="container">
            <div class="booking-widget glass-card p-4 rounded-4 shadow-xl" data-aos="fade-up" data-aos-delay="100">
                <form id="bookingForm" class="row g-3 align-items-end">
                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Check-in</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-calendar3 text-muted"></i>
                            </span>
                            <input type="date" class="form-control border-start-0" id="checkin" name="checkin" required>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <label class="form-label fw-semibold">Check-out</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-calendar3 text-muted"></i>
                            </span>
                            <input type="date" class="form-control border-start-0" id="checkout" name="checkout" required>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-2">
                        <label class="form-label fw-semibold">Guests</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-people text-muted"></i>
                            </span>
                            <select class="form-select border-start-0" name="guests" id="guests">
                                <option value="1">1 Guest</option>
                                <option value="2" selected>2 Guests</option>
                                <option value="3">3 Guests</option>
                                <option value="4">4 Guests</option>
                                <option value="5">5+ Guests</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-2">
                        <label class="form-label fw-semibold">Rooms</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-door-open text-muted"></i>
                            </span>
                            <select class="form-select border-start-0" name="rooms" id="roomsSelect">
                                <option value="1" selected>1 Room</option>
                                <option value="2">2 Rooms</option>
                                <option value="3">3 Rooms</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2">
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">
                            <i class="bi bi-search me-1"></i> Check Availability
                        </button>
                    </div>
                </form>
                
                <!-- Results will be shown here -->
                <div id="bookingResults" class="mt-4" style="display: none;"></div>
            </div>
        </div>
    </section>

    <!-- Rooms Section -->
    <section id="rooms" class="py-5">
        <div class="container py-5">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="text-primary fw-semibold" data-en="ACCOMMODATION" data-sw="MALAZI">ACCOMMODATION</span>
                <h2 class="display-5 fw-bold mt-2" data-en="Choose Your Perfect Stay" data-sw="Chagua Makaazi Yako Bora">Choose Your Perfect Stay</h2>
                <p class="lead text-muted mx-auto" style="max-width: 600px;" data-en="Comfortable, affordable rooms designed for backpackers and travelers exploring Tanzania." data-sw="Vyumba vya starehe na gharama nafuu vilivyoundwa kwa ajili ya wasafiri wanaogundua Tanzania.">
                    Comfortable, affordable rooms designed for backpackers and travelers exploring Tanzania.
                </p>
            </div>
            
            <div class="row g-4">
                <!-- Private Room -->
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="room-card h-100">
                        <div class="room-image">
                            <img src="https://lh3.googleusercontent.com/p/AF1QipP6li73ts9NJ41tp6HNfNYR8IQUTCSGPxE4ktZ7=s1360" alt="Private Room" class="img-fluid">
                            <span class="room-badge">Authentic</span>
                        </div>
                        <div class="room-content p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="fw-bold mb-1" data-en="Private Room" data-sw="Chumba Binafsi">Private Room</h4>
                                    <p class="text-muted mb-0"><i class="bi bi-person me-1"></i> <span data-en="1-2 Guests" data-sw="Wageni 1-2">1-2 Guests</span></p>
                                </div>
                                <div class="text-end">
                                    <span class="h4 text-primary fw-bold">$45</span>
                                    <p class="text-muted small mb-0">/<span data-en="night" data-sw="usiku">night</span></p>
                                </div>
                            </div>
                            <ul class="room-features list-unstyled mb-3">
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Incl. Breakfast & Dinner" data-sw="Chakula cha Asubuhi na Jioni">Incl. Breakfast & Dinner</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Laundry Included" data-sw="Huduma ya Dobi">Laundry Included</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Free Wi-Fi" data-sw="Wi-Fi ya Bure">Free Wi-Fi</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Shared Bathroom" data-sw="Choo cha Pamoja">Shared Bathroom</span></li>
                            </ul>
                            <button class="btn btn-outline-primary w-100 rounded-pill" onclick="selectRoom('private')" data-en="Book This Room" data-sw="Weka Nafasi">
                                Book This Room
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Dorm Room -->
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="room-card h-100">
                        <div class="room-image">
                            <img src="https://lh3.googleusercontent.com/p/AF1QipPQi8sT4dpAdRZpgdjHyvSoASkGAUmlIRVVALux=s1360" alt="Dorm Room" class="img-fluid">
                            <span class="room-badge bg-warning" data-en="Best Value" data-sw="Thamani Bora">Best Value</span>
                        </div>
                        <div class="room-content p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="fw-bold mb-1" data-en="Dormitory Bed" data-sw="Kitanda cha Somo">Dormitory Bed</h4>
                                    <p class="text-muted mb-0"><i class="bi bi-person me-1"></i> <span data-en="Per Person" data-sw="Kwa Mtu">Per Person</span></p>
                                </div>
                                <div class="text-end">
                                    <span class="h4 text-primary fw-bold">$20</span>
                                    <p class="text-muted small mb-0">/<span data-en="night" data-sw="usiku">night</span></p>
                                </div>
                            </div>
                            <ul class="room-features list-unstyled mb-3">
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Breakfast, Dinner & Laundry" data-sw="Chakula na Dobi">Breakfast, Dinner & Laundry</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Secure Lockers" data-sw="Makabati Salama">Secure Lockers</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Free Wi-Fi" data-sw="Wi-Fi ya Bure">Free Wi-Fi</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Social Atmosphere" data-sw="Hali ya Kijamii">Social Atmosphere</span></li>
                            </ul>
                            <button class="btn btn-outline-primary w-100 rounded-pill" onclick="selectRoom('dorm')" data-en="Book This Bed" data-sw="Weka Nafasi">
                                Book This Bed
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Camping Option -->
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="room-card h-100">
                        <div class="room-image">
                            <img src="https://lh3.googleusercontent.com/p/AF1QipNQsxZWRXSXpR9eTTPAwrO8YDC_x8JaptRp9bFO=s1360" alt="Camping" class="img-fluid">
                            <span class="room-badge bg-success" data-en="Adventure" data-sw="Matukio">Adventure</span>
                        </div>
                        <div class="room-content p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="fw-bold mb-1" data-en="Camping" data-sw="Kambi">Camping</h4>
                                    <p class="text-muted mb-0"><i class="bi bi-person me-1"></i> <span data-en="1-2 Guests" data-sw="Wageni 1-2">1-2 Guests</span></p>
                                </div>
                                <div class="text-end">
                                    <span class="h4 text-primary fw-bold">$8</span>
                                    <p class="text-muted small mb-0">/<span data-en="night" data-sw="usiku">night</span></p>
                                </div>
                            </div>
                            <ul class="room-features list-unstyled mb-3">
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Bring Your Own Tent" data-sw="Leta Hema Lako">Bring Your Own Tent</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Shared Facilities" data-sw="Huduma za Pamoja">Shared Facilities</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="BBQ Area Access" data-sw="Eneo la Choma">BBQ Area Access</span></li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <span data-en="Garden Views" data-sw="Mandhari ya Bustani">Garden Views</span></li>
                            </ul>
                            <button class="btn btn-outline-primary w-100 rounded-pill" onclick="selectRoom('camping')" data-en="Book Now" data-sw="Weka Nafasi">
                                Book Now
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Amenities Section -->
    <section id="amenities" class="py-5 bg-light">
        <div class="container py-5">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="text-primary fw-semibold">FACILITIES</span>
                <h2 class="display-5 fw-bold mt-2">Everything You Need</h2>
                <p class="lead text-muted mx-auto" style="max-width: 600px;">
                    Modern amenities to make your stay comfortable and memorable.
                </p>
            </div>
            
            <div class="row g-4">
                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="amenity-card text-center p-4 rounded-4 h-100">
                        <div class="amenity-icon mb-3">
                            <i class="bi bi-wifi"></i>
                        </div>
                        <h5 class="fw-semibold">Free Wi-Fi</h5>
                        <p class="text-muted small mb-0">High-speed internet throughout</p>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="150">
                    <div class="amenity-card text-center p-4 rounded-4 h-100">
                        <div class="amenity-icon mb-3">
                            <i class="bi bi-egg-fried"></i>
                        </div>
                        <h5 class="fw-semibold" data-en="Meals Included" data-sw="Chakula Kipo">Meals Included</h5>
                        <p class="text-muted small mb-0" data-en="Breakfast & Dinner included" data-sw="Asubuhi na Jioni">Breakfast & Dinner included</p>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="amenity-card text-center p-4 rounded-4 h-100">
                        <div class="amenity-icon mb-3">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h5 class="fw-semibold" data-en="24/7 Security" data-sw="Ulinzi 24/7">24/7 Security</h5>
                        <p class="text-muted small mb-0" data-en="Safe and secure environment" data-sw="Hali salama na tulivu">Safe and secure environment</p>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="250">
                    <div class="amenity-card text-center p-4 rounded-4 h-100">
                        <div class="amenity-icon mb-3">
                            <i class="bi bi-brightness-high"></i>
                        </div>
                        <h5 class="fw-semibold" data-en="Laundry" data-sw="Dobi">Laundry</h5>
                        <p class="text-muted small mb-0" data-en="Daily laundry service included" data-sw="Huduma ya kila siku">Daily laundry service included</p>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="amenity-card text-center p-4 rounded-4 h-100">
                        <div class="amenity-icon mb-3">
                            <i class="bi bi-book"></i>
                        </div>
                        <h5 class="fw-semibold">Travel Desk</h5>
                        <p class="text-muted small mb-0">Safari & tour bookings</p>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="250">
                    <div class="amenity-card text-center p-4 rounded-4 h-100">
                        <div class="amenity-icon mb-3">
                            <i class="bi bi-bicycle"></i>
                        </div>
                        <h5 class="fw-semibold">Bike Rental</h5>
                        <p class="text-muted small mb-0">Explore Arusha on two wheels</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <section id="gallery" class="py-5">
        <div class="container py-5">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="text-primary fw-semibold">GALLERY</span>
                <h2 class="display-5 fw-bold mt-2">Experience Our Hostel</h2>
            </div>
            
            <div class="row g-3">
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="gallery-item">
                        <img src="https://lh3.googleusercontent.com/p/AF1QipPtMLZ6QH56NZNFYTYUNIOQHJuIhhSpNXVx_4rX=s1360" alt="Hostel Exterior" class="img-fluid rounded-4">
                        <div class="gallery-overlay">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="150">
                    <div class="gallery-item">
                        <img src="https://lh3.googleusercontent.com/p/AF1QipPQi8sT4dpAdRZpgdjHyvSoASkGAUmlIRVVALux=s1360" alt="Dorm Room" class="img-fluid rounded-4">
                        <div class="gallery-overlay">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="gallery-item">
                        <img src="https://lh3.googleusercontent.com/p/AF1QipP6li73ts9NJ41tp6HNfNYR8IQUTCSGPxE4ktZ7=s1360" alt="Private Room" class="img-fluid rounded-4">
                        <div class="gallery-overlay">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="gallery-item">
                        <img src="https://lh3.googleusercontent.com/p/AF1QipNQsxZWRXSXpR9eTTPAwrO8YDC_x8JaptRp9bFO=s1360" alt="Garden Area" class="img-fluid rounded-4">
                        <div class="gallery-overlay">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="150">
                    <div class="gallery-item">
                        <img src="https://lh3.googleusercontent.com/p/AF1QipOMP1hb_TmAhFRnL-fwI6wx7dMGo1wICSo6dZHC=s1360" alt="Dining Area" class="img-fluid rounded-4">
                        <div class="gallery-overlay">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="gallery-item">
                        <img src="https://dynamic-media-cdn.tripadvisor.com/media/photo-o/31/37/81/a3/exterior.jpg?w=1200" alt="Hostel Entrance" class="img-fluid rounded-4">
                        <div class="gallery-overlay">
                            <i class="bi bi-arrows-fullscreen"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="py-5 bg-primary text-white">
        <div class="container py-5">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="text-white-50 fw-semibold">TESTIMONIALS</span>
