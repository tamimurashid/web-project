                                <label class="form-label fw-semibold">Email *</label>
                                <input type="email" class="form-control" name="email" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Phone *</label>
                                <input type="tel" class="form-control" name="phone" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Check-in Date *</label>
                                <input type="date" class="form-control" name="checkin" id="modalCheckin" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Check-out Date *</label>
                                <input type="date" class="form-control" name="checkout" id="modalCheckout" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Number of Guests</label>
                                <select class="form-select" name="guests">
                                    <option value="1">1 Guest</option>
                                    <option value="2" selected>2 Guests</option>
                                    <option value="3">3 Guests</option>
                                    <option value="4">4 Guests</option>
                                    <option value="5">5+ Guests</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Special Requests</label>
                                <textarea class="form-control" rows="2" name="special_requests" placeholder="Any special requirements..."></textarea>
                            </div>
                            
                            <div class="col-12 mt-4">
                                <div class="booking-summary bg-light p-3 rounded-3">
                                    <h6 class="fw-bold mb-3">Booking Summary</h6>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Room Type:</span>
                                        <span class="fw-semibold" id="summaryRoom">-</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Nights:</span>
                                        <span class="fw-semibold" id="summaryNights">-</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Price per night:</span>
                                        <span class="fw-semibold" id="summaryPrice">-</span>
                                    </div>
                                    <hr>
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-bold">Total:</span>
                                        <span class="fw-bold text-primary" id="summaryTotal">-</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-12 mt-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="termsCheck" required>
                                    <label class="form-check-label" for="termsCheck">
                                        I agree to the <a href="#">Terms & Conditions</a> and <a href="#">Cancellation Policy</a>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4" onclick="submitBooking()">
                        <i class="bi bi-lock me-1"></i> Confirm Booking
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Success Modal -->
